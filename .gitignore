# Built application files
*.apk
*.ap_

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# Intellij
*.iml
.idea/workspace.xml
.idea/libraries

# Keystore files
*.jks

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
app/release/*
app/*/release/
app/src/main/res/values/publickey.xml
.idea/
/.kotlin/*

# Claude Code per-project state
.claude/

# Regenerable Play Store screenshot export (produced by scripts/generate-store-screenshots.sh).
# The committed screenshotTest reference/ images are the source of truth; this is just the
# clean, upload-ready copy and can be regenerated on demand.
/Play Store/Generated Screenshots/
