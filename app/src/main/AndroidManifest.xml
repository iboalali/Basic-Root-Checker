<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <uses-sdk tools:overrideLibrary="androidx.core.splashscreen" />

    <queries>
        <package android:name="com.topjohnwu.magisk" />
        <package android:name="com.topjohnwu.magisk.debug" />
        <package android:name="com.topjohnwu.magisk.canary" />
        <package android:name="com.topjohnwu.magisk.alpha" />
    </queries>

    <application
        android:name=".BasicRootCheckerApplication"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher_v2"
        android:localeConfig="@xml/app_locales_config"
        android:label="@string/app_name"
        android:theme="@style/Theme.iboalali.Main"
        tools:targetApi="33">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.iboalali.SplashScreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

        <provider
            android:name="com.telemetrydeck.sdk.TelemetryDeckInitProvider"
            android:authorities="${applicationId}.telemetrydeckinitprovider"
            tools:node="remove" />
    </application>

</manifest>
